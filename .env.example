# =============================================
# ReviewFlow — Environment Variables Template
# Copy to .env.local and fill in real values
# =============================================

# ---- Next.js & Deployment ----
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ---- NextAuth ----
NEXTAUTH_SECRET=your_nextauth_secret_32_chars_min
NEXTAUTH_URL=http://localhost:3000

# ---- PMS Integrations ----
MINDBODY_CLIENT_ID=your_mindbody_client_id
MINDBODY_CLIENT_SECRET=your_mindbody_client_secret
VAGARO_CLIENT_ID=your_vagaro_client_id
VAGARO_CLIENT_SECRET=your_vagaro_client_secret
ACUITY_CLIENT_ID=your_acuity_client_id
ACUITY_CLIENT_SECRET=your_acuity_client_secret

# ---- Encryption (generate: openssl rand -hex 16) ----
ENCRYPTION_KEY=your_encryption_key_32_chars

# ---- Cron Secret (generate: openssl rand -hex 16) ----
CRON_SECRET=your_cron_secret_key

# ---- Google OAuth (for future Google sign-in) ----
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret

# ---- Gmail API (for sending review request emails) ----
GMAIL_REFRESH_TOKEN=your_gmail_refresh_token
GMAIL_ACCESS_TOKEN=your_gmail_access_token

# ---- Anthropic / Claude API ----
ANTHROPIC_API_KEY=your_anthropic_api_key

# ---- MedSpa News Ideas Pipeline ----
# Serper.dev (Google News search): https://serper.dev
SERPER_API_KEY=your_serper_dev_api_key
# Notion integration token: https://www.notion.so/my-integrations
NOTION_API_KEY=your_notion_internal_integration_secret
# ID of the "MedSpa Automation Ideas" database
# Required schema: Title (title), Source (url), Date (date),
#   Summary (rich_text), Automation Angle (rich_text), Status (select)
NOTION_MEDSPA_IDEAS_DB_ID=your_notion_database_id
